<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Meeting Summaries</title>
    <style>
      body { font-family: system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, Noto Sans, "Apple Color Emoji", "Segoe UI Emoji"; margin: 2rem; line-height: 1.6; color: #111; }
      a { color: #0366d6; text-decoration: none; }
      a:hover { text-decoration: underline; }
      h1 { margin-bottom: 1rem; }
      ul { list-style: none; padding: 0; }
      li { margin: 0.5rem 0; }
      .muted { color: #555; }
    </style>
  </head>
  <body>
    <h1>Meeting Summaries</h1>
    <ul>
      {% for p in pages %}
      <li>
        <a href="{{ p.filename }}">{{ p.title }}</a>
      </li>
      {% else %}
      <li class="muted">No meetings yet.</li>
      {% endfor %}
    </ul>
  </body>
  </html>


