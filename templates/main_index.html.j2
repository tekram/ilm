<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="color-scheme" content="light" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Islamic Learning Materials</title>
    <style>
      html { background: #fff; color: #111; color-scheme: light; }
      body { font-family: system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, Noto Sans, "Apple Color Emoji", "Segoe UI Emoji"; margin: 2rem; line-height: 1.6; color: #111; }
      a { color: #0366d6; text-decoration: none; }
      a:hover { text-decoration: underline; }
      h1 { margin-bottom: 1rem; color: #24292e; }
      h2 { margin-top: 2rem; margin-bottom: 0.5rem; color: #586069; }
      .meeting-type { 
        background: #f6f8fa; 
        border: 1px solid #d1d5da; 
        border-radius: 6px; 
        padding: 1.5rem; 
        margin: 1rem 0; 
        transition: background-color 0.2s;
      }
      .meeting-type:hover { background: #f1f3f4; }
      .meeting-type h3 { margin-top: 0; margin-bottom: 0.5rem; }
      .meeting-type p { color: #586069; margin-bottom: 1rem; }
      .meeting-type a { 
        display: inline-block; 
        background: #0366d6; 
        color: white; 
        padding: 0.5rem 1rem; 
        border-radius: 4px; 
        text-decoration: none;
        font-weight: 500;
      }
      .meeting-type a:hover { background: #0256cc; text-decoration: none; }
      .subtitle { color: #586069; margin-bottom: 2rem; }
    </style>
  </head>
  <body>
    <h1>Islamic Learning Materials</h1>
    <p class="subtitle">Summaries and transcripts from various Islamic studies lessons</p>
    
    {% for type_name, meeting_type in meeting_types.items() %}
    <div class="meeting-type">
      <h3>{{ meeting_type.display_name }}</h3>
      <p>{{ meeting_type.description }}</p>
      <a href="{{ meeting_type.output_dir }}/index.html">View {{ meeting_type.display_name }} Sessions →</a>
    </div>
    {% endfor %}
  </body>
</html>
