<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="color-scheme" content="light" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ meeting_type.display_name }} Sessions</title>
    <style>
      html { background: #fff; color: #111; color-scheme: light; }
      body { font-family: system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, Noto Sans, "Apple Color Emoji", "Segoe UI Emoji"; margin: 2rem; line-height: 1.6; color: #111; }
      a { color: #0366d6; text-decoration: none; }
      a:hover { text-decoration: underline; }
      h1 { margin-bottom: 0.5rem; color: #24292e; }
      .nav { margin-bottom: 2rem; }
      .nav a { color: #586069; font-size: 0.9rem; }
      .description { color: #586069; margin-bottom: 2rem; font-style: italic; }
      ul { list-style: none; padding: 0; }
      li { 
        margin: 0.75rem 0; 
        padding: 0.75rem; 
        border-left: 3px solid #e1e4e8; 
        background: #f8f9fa;
        border-radius: 0 4px 4px 0;
      }
      li:hover { background: #f1f3f4; border-left-color: #0366d6; }
      .muted { color: #586069; font-style: italic; }
      .session-link { font-weight: 500; }
      .session-date { font-size: 0.9rem; color: #586069; margin-left: 0.5rem; }
    </style>
  </head>
  <body>
    <div class="nav">
      <a href="../index.html">← All Learning Materials</a>
    </div>
    
    <h1>{{ meeting_type.display_name }}</h1>
    <p class="description">{{ meeting_type.description }}</p>
    
    <ul>
      {% for page in pages %}
      <li>
        <a href="meetings/{{ page.filename.split('/')[-1] }}" class="session-link">{{ page.title }}</a>
        <span class="session-date">{{ page.start_time[:10] }}</span>
      </li>
      {% else %}
      <li class="muted">No sessions available yet.</li>
      {% endfor %}
    </ul>
  </body>
</html>
